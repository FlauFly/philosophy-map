---
const articles = [
{
    id: 'plato',
    title: 'Plato'
},
{
    id: 'socrates',
    title: 'Socrates'
},
{
    id: 'aristotle',
    title: 'Aristotle'
}
];
---
<div class="search-bar">
    <input type="text" placeholder="Search article..." id="search-input">
    <ul id="suggestion-box"></ul>
</div>


<style is:global>
    .search-bar {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .search-bar input {
        padding: 10px;
        border-radius: 5px;
        width: 30vw;
        border: 5px solid rgb(102, 201, 235);
    }

    .search-bar input:focus-visible {
        box-shadow: rgb(102, 201, 235) 0 0 8px;
        outline: none;
    }

    #suggestion-box {
        background-color: white;
        width: 32vw;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .suggestion {
        padding: 8px 16px;
        border-bottom: 1px solid #ddd;
    }

    .suggestion:last-child {
        border-bottom: none;
    }

    .suggestion:hover {
        background-color: rgb(175, 226, 243);
    }
</style>

<script>
    const articles = [
        {
            id: 'plato',
            title: 'Plato'
        },
        {
            id: 'socrates',
            title: 'Socrates'
        },
        {
            id: 'aristotle',
            title: 'Aristotle'
        }
    ];

    const input = document.querySelector("input") as HTMLInputElement;
    const suggestionBox = document.getElementById("suggestion-box") as HTMLElement;

    const renderList = function(e: Event) {
        let searchText = !!e ? (e.target as HTMLInputElement).value : '';
        if (searchText.length == 0) {
            suggestionBox.innerHTML = '';
            e.stopPropagation();
            return;
        }

        const filtered = articles.filter(article =>
            article.title.toLowerCase().includes(searchText.toLowerCase())
        )

        let childrenElement = '';
        for (const article of filtered) {
            childrenElement += `<li class="suggestion"><a href=${article.id}>${article.title}</a></li>`;
        }

        suggestionBox.innerHTML = childrenElement;
    }

    input.addEventListener('keyup', renderList)  
</script>