---
let articles = ['Plato', "Aristotle", "Socrates", "Abstract Objects"];
---
<div class="search-bar">
    <input type="text" placeholder="Search article...">
    <ul class="suggestion-box">
        {
            articles.map((article) => (
                <li>{article}</li>
            ))
        }
    </ul>
</div>


<style>
    .search-bar {
        display: flex;
        justify-content: center;
        align-items: center;
        flex-direction: column;
    }

    .search-bar input {
        padding: 10px;
        border-radius: 5px;
        width: 30vw;
        border: 5px solid rgb(102, 201, 235);
    }

    .search-bar input:focus-visible {
        box-shadow: rgb(102, 201, 235) 0 0 8px;
        outline: none;
    }

    .suggestion-box {
        background-color: white;
        width: 32vw;
        list-style: none;
        padding: 0;
        border: 1px solid #ddd;
        margin: 0;
    }

    .suggestion-box li {
        padding: 8px 16px;
        border-bottom: 1px solid #ddd;
    }

    .suggestion-box li:last-child {
        border-bottom: none;
    }

    .suggestion-box li:hover {
        background-color: rgb(175, 226, 243);
    }
</style>